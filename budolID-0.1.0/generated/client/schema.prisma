generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String
  phoneNumber        String    @unique
  firstName          String?
  lastName           String?
  role               UserRole  @default(USER)
  department         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  isFaceVerified     Boolean   @default(false)
  kycData            Json?
  kycStatus          KYCStatus @default(NONE)
  kycTier            KYCTier   @default(BASIC)
  otpCode            String?
  otpExpiresAt       DateTime?
  otpUpdatedAt       DateTime?
  emailVerified      Boolean   @default(false)
  phoneVerified      Boolean   @default(false)
  avatarUrl          String?
  faceTemplate       String?
  lastLoginAt        DateTime?
  pinHash            String?
  biometricKeyId     String?
  biometricPublicKey Bytes?
  trustedDevices     String?
  sessions           Session[]
}

model Session {
  id        String        @id @default(uuid())
  userId    String
  appId     String?
  token     String        @unique
  expiresAt DateTime
  createdAt DateTime      @default(now())
  app       EcosystemApp? @relation(fields: [appId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
}

model EcosystemApp {
  id          String    @id @default(uuid())
  name        String    @unique
  apiKey      String    @unique
  apiSecret   String    @unique
  redirectUri String
  createdAt   DateTime  @default(now())
  sessions    Session[]
}

enum UserRole {
  USER
  ADMIN
  MERCHANT
  DRIVER
  STAFF
  DEACTIVATED
}

enum KYCStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum KYCTier {
  BASIC
  SEMI_VERIFIED
  FULLY_VERIFIED
}
