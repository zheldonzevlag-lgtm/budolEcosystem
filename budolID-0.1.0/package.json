{
  "name": "budol-id-sso",
  "version": "1.0.0",
  "description": "Budol Ecosystem SSO Service",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:phone": "jest tests/phoneNormalization.test.js",
    "test:login": "jest tests/dualIdentifierLogin.test.js",
    "migrate": "prisma migrate deploy",
    "generate": "prisma generate",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "*.js",
      "utils/*.js",
      "!node_modules/**",
      "!coverage/**",
      "!generated/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}