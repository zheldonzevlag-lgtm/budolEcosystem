{
    "family": "budol-auth-task",
    "networkMode": "awsvpc",
    "executionRoleArn": "arn:aws:iam::194442925745:role/BudolECSExecutionRole",
    "containerDefinitions": [
        {
            "name": "budol-auth-service",
            "image": "194442925745.dkr.ecr.ap-southeast-1.amazonaws.com/budol-auth-service:v14",
            "portMappings": [
                {
                    "containerPort": 8001,
                    "hostPort": 8001,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "PORT",
                    "value": "8001"
                },
                {
                    "name": "NODE_ENV",
                    "value": "production"
                }
            ],
            "secrets": [
                {
                    "name": "DATABASE_URL",
                    "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:194442925745:secret:budol/id-db-url-DbaEzJ"
                },
                {
                    "name": "JWT_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:194442925745:secret:budol/jwt-secret-RlaVaW"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/budol-auth",
                    "awslogs-region": "ap-southeast-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512"
}
