{
    "InstanceIds": [
        "i-0335b8c303baaaee0"
    ],
    "DocumentName": "AWS-RunShellScript",
    "Comment": "Get SSL certs via dual DuckDNS accounts using acme.sh (path fixed)",
    "Parameters": {
        "commands": [
            "cd /root",
            "wget -O acme.sh-master.tar.gz https://github.com/acmesh-official/acme.sh/archive/master.tar.gz || true",
            "tar -zxf acme.sh-master.tar.gz || true",
            "cd acme.sh-master || true",
            "./acme.sh --install -m galvezjon59@gmail.com --nocron || true",
            "export DuckDNS_Token=\"db0964a1-387c-419a-9272-f87e38b8a542\"",
            "/.acme.sh/acme.sh --issue --dns dns_duckdns -d budoladmin.duckdns.org -d budolid.duckdns.org -d budolpay.duckdns.org -d budolshap.duckdns.org -d budolws.duckdns.org --server letsencrypt --dnssleep 120",
            "export DuckDNS_Token=\"d0ce0193-6d88-4ea3-b750-ed25d1add7de\"",
            "/.acme.sh/acme.sh --issue --dns dns_duckdns -d budolaccounting.duckdns.org --server letsencrypt --dnssleep 120",
            "cp /.acme.sh/budoladmin.duckdns.org_ecc/fullchain.cer /home/ubuntu/cert1.crt || true",
            "cp /.acme.sh/budoladmin.duckdns.org_ecc/budoladmin.duckdns.org.key /home/ubuntu/cert1.key || true",
            "cp /.acme.sh/budolaccounting.duckdns.org_ecc/fullchain.cer /home/ubuntu/cert2.crt || true",
            "cp /.acme.sh/budolaccounting.duckdns.org_ecc/budolaccounting.duckdns.org.key /home/ubuntu/cert2.key || true",
            "echo 'ACME.SH RUN DONE'"
        ]
    }
}
