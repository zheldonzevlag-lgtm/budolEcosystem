    "aws_cli_commands": {
        "get_alb_dns": "aws cloudformation describe-stacks --stack-name budolEcosystem-ECS --query 'Stacks[0].Outputs[?OutputKey==`InternalALBDNSName`].OutputValue' --output text",
        "get_hosted_zone_id": "aws route53 list-hosted-zones --query 'HostedZones[?Name==`budol.internal.`].Id' --output text",
        "apply_changes": "aws route53 change-resource-record-sets --hosted-zone-id HOSTED_ZONE_ID --change-batch file://route53-changes.json",
        "list_records": "aws route53 list-resource-record-sets --hosted-zone-id HOSTED_ZONE_ID"
    },
    "json_batch_file_example": {
        "comment": "Create A records for budolEcosystem services",
        "changes": [
            {
                "action": "CREATE",
                "resource_record_set": {
                    "name": "budolid.budol.internal",
                    "type": "A",
                    "alias_target": {
                        "hosted_zone_id": "Z2FDTNDATAQYW2",
                        "dns_name": "budolEcosystem-InternalALB-xxxxx.ap-southeast-1.elb.amazonaws.com",
                        "evaluate_target_health": true
                    }
                }
            }
        ]
    },
    "verification_commands": {
        "list_all_records": "aws route53 list-resource-record-sets --hosted-zone-id HOSTED_ZONE_ID --output table",
        "test_dns_from_ec2": "nslookup budolid.budol.internal",
        "test_curl": "curl http://budolid.budol.internal/health"
    }
}