{
    "comment": "Route 53 Internal DNS Configuration for budolEcosystem",
    "description": "Private Hosted Zone: budol.internal",
    "instructions": [
        "Get Internal ALB DNS Name from CloudFormation stack output:",
        "aws cloudformation describe-stacks --stack-name budolEcosystem-ECS --query 'Stacks[0].Outputs[?OutputKey==`InternalALBDNSName`].OutputValue' --output text",
        "",
        "Replace HOSTED_ZONE_ID with your Route 53 Private Hosted Zone ID",
        "Replace INTERNAL_ALB_DNS_NAME with the actual Internal ALB DNS name"
    ],
    "records": [
        {
            "name": "budolid.budol.internal",
            "type": "A",
            "alias_target": {
                "hosted_zone_id": "Z2FDTNDATAQYW2",
                "dns_name": "INTERNAL_ALB_DNS_NAME",
                "evaluate_target_health": true
            }
        },
        {
            "name": "budolaccounting.budol.internal",
            "type": "A",
