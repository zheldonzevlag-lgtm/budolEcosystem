generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ChartOfAccount {
  id            String        @id @default(uuid())
  code          String        @unique
  name          String
  type          AccountType
  description   String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  ledgerEntries LedgerEntry[]
}

model LedgerEntry {
  id            String         @id @default(uuid())
  accountId     String
  transactionId String?
  referenceId   String
  description   String
  debit         Decimal        @default(0.0) @db.Decimal(18, 2)
  credit        Decimal        @default(0.0) @db.Decimal(18, 2)
  createdAt     DateTime       @default(now())
  account       ChartOfAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([transactionId])
  @@index([referenceId])
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  phoneNumber   String        @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  role          UserRole      @default(USER)
  kycStatus     KYCStatus     @default(NONE)
  kycData       Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  auditLogs     AuditLog[]
  sessions      Session[]
  receivedTrans Transaction[] @relation("ReceivedTransactions")
  transactions  Transaction[] @relation("UserTransactions")
  wallet        Wallet?
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  appId     String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model EcosystemApp {
  id          String   @id @default(uuid())
  name        String   @unique
  apiKey      String   @unique
  redirectUri String
  createdAt   DateTime @default(now())
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0.0) @db.Decimal(18, 2)
  currency  String   @default("PHP")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id           String            @id @default(uuid())
  amount       Decimal           @db.Decimal(18, 2)
  type         TransactionType
  status       TransactionStatus @default(PENDING)
  description  String?
  senderId     String?
  receiverId   String?
  referenceId  String            @unique
  fee          Decimal           @default(0.0) @db.Decimal(18, 2)
  createdAt    DateTime          @default(now())
  completedAt  DateTime?
  settlementId String?
  dispute      Dispute?
  receiver     User?             @relation("ReceivedTransactions", fields: [receiverId], references: [id])
  sender       User?             @relation("UserTransactions", fields: [senderId], references: [id])
  settlement   Settlement?       @relation(fields: [settlementId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([referenceId])
  @@index([settlementId])
}

model Settlement {
  id            String           @id @default(uuid())
  merchantId    String
  amount        Decimal          @db.Decimal(18, 2)
  feeDeducted   Decimal          @db.Decimal(18, 2)
  netAmount     Decimal          @db.Decimal(18, 2)
  status        SettlementStatus @default(PENDING)
  bankReference String?
  periodStart   DateTime
  periodEnd     DateTime
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  transactions  Transaction[]

  @@index([merchantId])
  @@index([status])
}

model Dispute {
  id              String        @id @default(uuid())
  transactionId   String        @unique
  reason          String
  status          DisputeStatus @default(OPEN)
  evidenceUrl     String?
  resolutionNotes String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  transaction     Transaction   @relation(fields: [transactionId], references: [id])
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  isSecret    Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

enum UserRole {
  USER
  STAFF
  ADMIN
  SYSTEM
}

enum KYCStatus {
  PENDING
  VERIFIED
  REJECTED
  NONE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum TransactionType {
  CASH_IN
  CASH_OUT
  P2P_TRANSFER
  MERCHANT_PAYMENT
  REFUND
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum SettlementStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REFUNDED
  RESOLVED_DECLINED
}
