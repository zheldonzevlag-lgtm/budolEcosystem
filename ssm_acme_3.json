{
    "InstanceIds": [
        "i-0335b8c303baaaee0"
    ],
    "DocumentName": "AWS-RunShellScript",
    "Comment": "Get SSL cert 3 (budolpay)",
    "Parameters": {
        "commands": [
            "export DuckDNS_Token=\"db0964a1-387c-419a-9272-f87e38b8a542\"",
            "/.acme.sh/acme.sh --issue --dns dns_duckdns -d budolpay.duckdns.org --server letsencrypt --dnssleep 120",
            "cp /.acme.sh/budolpay.duckdns.org_ecc/fullchain.cer /home/ubuntu/cert_pay.crt || true",
            "cp /.acme.sh/budolpay.duckdns.org_ecc/budolpay.duckdns.org.key /home/ubuntu/cert_pay.key || true"
        ]
    }
}
