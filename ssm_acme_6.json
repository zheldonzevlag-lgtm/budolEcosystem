{
    "InstanceIds": [
        "i-0335b8c303baaaee0"
    ],
    "DocumentName": "AWS-RunShellScript",
    "Comment": "Get SSL cert 6 (budolaccounting)",
    "Parameters": {
        "commands": [
            "export DuckDNS_Token=\"d0ce0193-6d88-4ea3-b750-ed25d1add7de\"",
            "/.acme.sh/acme.sh --issue --dns dns_duckdns -d budolaccounting.duckdns.org --server letsencrypt --dnssleep 120",
            "cp /.acme.sh/budolaccounting.duckdns.org_ecc/fullchain.cer /home/ubuntu/cert_acc.crt || true",
            "cp /.acme.sh/budolaccounting.duckdns.org_ecc/budolaccounting.duckdns.org.key /home/ubuntu/cert_acc.key || true"
        ]
    }
}
