{
    "commands": [
        "# Create SSM Parameters for budolEcosystem ECS Production",
        "# ==============================",
        "# ALB Configuration",
        "# ==============================",
        "aws ssm put-parameter --name '/budolEcosystem/production/ALB_EXTERNAL_DNS_NAME' --value 'budolEcosystem-ALB-xxxxxxxxx.ap-southeast-1.elb.amazonaws.com' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/ALB_INTERNAL_DNS_NAME' --value 'budolEcosystem-InternalALB-xxxxxxxxx.ap-southeast-1.elb.amazonaws.com' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/ALB_HTTPS_PORT' --value '443' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/ALB_HTTP_PORT' --value '80' --type String --overwrite",
        "# ==============================",
        "# Database Configuration",
        "# ==============================",
        "aws ssm put-parameter --name '/budolEcosystem/production/DATABASE_HOST' --value 'your-rds-endpoint.amazonaws.com' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/DATABASE_PORT' --value '5432' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/DATABASE_NAME' --value 'budolshap_1db' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/DATABASE_USER' --value 'postgres' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/DATABASE_SCHEMA_BUDOLID' --value 'budolid' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/DATABASE_SCHEMA_BUDOLSHAP' --value 'public' --type String --overwrite",
        "# ==============================",
        "# Redis Configuration",
        "# ==============================",
        "aws ssm put-parameter --name '/budolEcosystem/production/REDIS_HOST' --value 'your-redis-endpoint.cache.amazonaws.com' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/REDIS_PORT' --value '6379' --type String --overwrite",
        "# ==============================",
        "# Internal DNS Service URLs (via Internal ALB)",
        "# ==============================",
        "aws ssm put-parameter --name '/budolEcosystem/production/INTERNAL_BUDOLID_URL' --value 'http://budolid.budol.internal' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/INTERNAL_BUDOLACCOUNTING_URL' --value 'http://budolaccounting.budol.internal' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/INTERNAL_BUDOLPAY_GATEWAY_URL' --value 'http://budolpay-gateway.budol.internal' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/INTERNAL_BUDOLPAY_AUTH_URL' --value 'http://budolpay-auth.budol.internal' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/INTERNAL_BUDOLPAY_WALLET_URL' --value 'http://budolpay-wallet.budol.internal' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/INTERNAL_BUDOLPAY_TRANSACTION_URL' --value 'http://budolpay-transaction.budol.internal' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/INTERNAL_BUDOLPAY_PAYMENT_URL' --value 'http://budolpay-payment.budol.internal' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/INTERNAL_BUDOLPAY_KYC_URL' --value 'http://budolpay-kyc.budol.internal' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/INTERNAL_BUDOLPAY_SETTLEMENT_URL' --value 'http://budolpay-settlement.budol.internal' --type String --overwrite",
        "# ==============================",
        "# ECS Service URLs (for container-to-container)",
        "# ==============================",
        "aws ssm put-parameter --name '/budolEcosystem/production/SERVICE_BUDOLID_URL' --value 'http://budolid:8000' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/SERVICE_BUDOLACCOUNTING_URL' --value 'http://budolaccounting:8005' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/SERVICE_BUDOLPAY_GATEWAY_URL' --value 'http://budolpay-gateway:8080' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/SERVICE_BUDOLPAY_AUTH_URL' --value 'http://budolpay-auth:8001' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/SERVICE_BUDOLPAY_WALLET_URL' --value 'http://budolpay-wallet:8002' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/SERVICE_BUDOLPAY_TRANSACTION_URL' --value 'http://budolpay-transaction:8003' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/SERVICE_BUDOLPAY_PAYMENT_URL' --value 'http://budolpay-payment:8004' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/SERVICE_BUDOLPAY_KYC_URL' --value 'http://budolpay-kyc:8006' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/SERVICE_BUDOLPAY_SETTLEMENT_URL' --value 'http://budolpay-settlement:8007' --type String --overwrite",
        "# ==============================",
        "# External URLs (for public access via Internet ALB)",
        "# ==============================",
        "aws ssm put-parameter --name '/budolEcosystem/production/EXTERNAL_BUDOLID_URL' --value 'https://budolid.yourdomain.com' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/EXTERNAL_BUDOLACCOUNTING_URL' --value 'https://accounting.yourdomain.com' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/EXTERNAL_BUDOLPAY_URL' --value 'https://api.budolpay.yourdomain.com' --type String --overwrite",
        "# ==============================",
        "# Application Settings",
        "# ==============================",
        "aws ssm put-parameter --name '/budolEcosystem/production/NODE_ENV' --value 'production' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/TZ' --value 'Asia/Manila' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/LOG_LEVEL' --value 'info' --type String --overwrite",
        "# ==============================",
        "# ECS Cluster Settings",
        "# ==============================",
        "aws ssm put-parameter --name '/budolEcosystem/production/ECS_CLUSTER_NAME' --value 'budolEcosystem-production' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/ECS_VPC_ID' --value 'vpc-xxxxxxxx' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/ECS_SUBNET_PUBLIC_1' --value 'subnet-xxxxxxxx' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/ECS_SUBNET_PUBLIC_2' --value 'subnet-xxxxxxxx' --type String --overwrite",
        "# ==============================",
        "# Private Hosted Zone Configuration",
        "# ==============================",
        "aws ssm put-parameter --name '/budolEcosystem/production/HOSTED_ZONE_NAME' --value 'budol.internal' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/HOSTED_ZONE_ID' --value 'ZXXXXXXXXXXXXX' --type String --overwrite",
        "# ==============================",
        "# Feature Flags",
        "# ==============================",
        "aws ssm put-parameter --name '/budolEcosystem/production/FEATURE_KYC_ENABLED' --value 'true' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/FEATURE_SETTLEMENT_ENABLED' --value 'true' --type String --overwrite",
        "aws ssm put-parameter --name '/budolEcosystem/production/FEATURE_PAYMENT_GATEWAY_ENABLED' --value 'true' --type String --overwrite"
    ]
}