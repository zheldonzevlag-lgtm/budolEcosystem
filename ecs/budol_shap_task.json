{
    "family": "budol-shap-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "budol-shap",
            "image": "194442925745.dkr.ecr.ap-southeast-1.amazonaws.com/budol-shap:v14",
            "portMappings": [
                {
                    "containerPort": 3000,
                    "hostPort": 3000,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "NODE_ENV",
                    "value": "production"
                },
                {
                    "name": "NEXT_PUBLIC_APP_URL",
                    "value": "https://budolshap.duckdns.org"
                },
                {
                    "name": "NEXT_PUBLIC_BASE_URL",
                    "value": "https://budolshap.duckdns.org"
                },
                {
                    "name": "NEXT_PUBLIC_SSO_URL",
                    "value": "https://budolid.duckdns.org"
                },
                {
                    "name": "SSO_URL",
                    "value": "https://budolid.duckdns.org"
                },
                {
                    "name": "CLOUDINARY_API_KEY",
                    "value": "537684148625265"
                }
            ],
            "secrets": [
                {
                    "name": "DATABASE_URL",
                    "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:194442925745:secret:budol/db-url-NxLd8V"
                },
                {
                    "name": "JWT_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:194442925745:secret:budol/jwt-secret-RlaVaW"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/budol-shap",
                    "awslogs-region": "ap-southeast-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "executionRoleArn": "arn:aws:iam::194442925745:role/BudolECSExecutionRole"
}