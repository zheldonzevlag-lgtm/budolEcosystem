{
    "family": "budolPayGateway",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "executionRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/budolPayGatewayTaskRole",
    "containerDefinitions": [
        {
            "name": "budolpay-gateway",
            "image": "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/budolecosystem/budolpay-gateway:${IMAGE_TAG}",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "NODE_ENV",
                    "value": "production"
                },
                {
                    "name": "PORT",
                    "value": "8080"
                },
                {
                    "name": "TZ",
                    "value": "Asia/Manila"
                },
                {
                    "name": "AUTH_SERVICE_URL",
                    "value": "http://budolpay-auth:8001"
                },
                {
                    "name": "WALLET_SERVICE_URL",
                    "value": "http://budolpay-wallet:8002"
                },
                {
                    "name": "TRANSACTION_SERVICE_URL",
                    "value": "http://budolpay-transaction:8003"
                },
                {
                    "name": "PAYMENT_GATEWAY_URL",
                    "value": "http://budolpay-payment:8004"
                },
                {
                    "name": "SETTLEMENT_SERVICE_URL",
                    "value": "http://budolpay-settlement:8007"
                },
                {
                    "name": "VERIFICATION_SERVICE_URL",
                    "value": "http://budolpay-kyc:8006"
                },
                {
                    "name": "ACCOUNTING_SERVICE_URL",
                    "value": "http://budolaccounting:8005"
                },
                {
                    "name": "ID_SERVICE_URL",
                    "value": "http://budolid:8000"
                },
                {
                    "name": "REDIS_URL",
                    "value": "redis://redis-cluster:6379"
                }
            ],
            "secrets": [
                {
                    "name": "DATABASE_URL",
                    "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:budolEcosystem/DATABASE_URL"
                },
                {
                    "name": "REDIS_PASSWORD",
                    "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:budolEcosystem/REDIS_PASSWORD"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/budolPayGateway",
                    "awslogs-region": "${AWS_REGION}",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "wget --spider -q http://localhost:8080/health || exit 1"
                ],
                "interval": 30,
                "timeout": 10,
                "retries": 3,
                "startPeriod": 60
            }
        }
    ]
}