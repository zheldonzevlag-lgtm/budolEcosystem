{
    "InstanceIds": [
        "i-0335b8c303baaaee0"
    ],
    "DocumentName": "AWS-RunShellScript",
    "Comment": "Fetch SSL cert bodies and keys",
    "Parameters": {
        "commands": [
            "DOMAIN_LIST=\"budoladmin budolid budolpay budolshap budolws budolaccounting\"",
            "echo '{'",
            "for d in $DOMAIN_LIST; do",
            "  CERT_DIR=\"/.acme.sh/${d}.duckdns.org_ecc\"",
            "  echo \"\\\"${d}_body\\\": \\\"$(cat ${CERT_DIR}/${d}.duckdns.org.cer | tr '\\n' '#' )\\\",\"",
            "  echo \"\\\"${d}_key\\\": \\\"$(cat ${CERT_DIR}/${d}.duckdns.org.key | tr '\\n' '#' )\\\",\"",
            "  echo \"\\\"${d}_chain\\\": \\\"$(cat ${CERT_DIR}/ca.cer | tr '\\n' '#' )\\\",\"",
            "done",
            "echo \"\\\"end\\\": \\\"true\\\"\"",
            "echo '}'"
        ]
    }
}
