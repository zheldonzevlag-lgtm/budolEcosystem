{
  "manifest_version": 3,
  "name": "BudolShap Knowledge Base Shortcut",
  "version": "1.0.0",
  "description": "Quick access to BudolShap Knowledge Base with Ctrl+Shift+K (Cmd+Shift+K on Mac)",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*budolshap*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "open-knowledge-base": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open BudolShap Knowledge Base"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Knowledge Base"
  }
}

