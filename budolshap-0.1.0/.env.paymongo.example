# PayMongo Configuration
# Get your API keys from: https://dashboard.paymongo.com/developers/api-keys

# Secret Key (starts with sk_test_ for test mode, sk_live_ for production)
PAYMONGO_SECRET_KEY=sk_test_your_secret_key_here

# Public Key (starts with pk_test_ for test mode, pk_live_ for production)
PAYMONGO_PUBLIC_KEY=pk_test_your_public_key_here

# Site URL for redirects (no trailing slash)
# For local development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
