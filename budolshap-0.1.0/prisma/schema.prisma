generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String           @id
  name                 String
  email                String           @unique
  password             String
  phoneNumber          String?          @unique
  image                String
  cart                 Json             @default("{}")
  accountType          AccountType      @default(BUYER)
  emailVerified        Boolean          @default(false)
  isAdmin              Boolean          @default(false)
  isMember             Boolean          @default(false)
  isCoopMember         Boolean          @default(false)
  membershipStatus     MembershipStatus @default(NONE)
  coopMembershipStatus MembershipStatus @default(NONE)
  emailVerifyToken     String?
  resetToken           String?
  resetTokenExpiry     DateTime?
  role                 String           @default("USER")
  permissions          Json?            @default("[]")
  metadata             Json?            @default("{}")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?
  buyerReturnRate      Float?           @default(0.0)
  codUnpaidCount       Int?             @default(0)
  Address              Address[]
  auditLogs            AuditLog[]
  Cart                 Cart?
  buyerChats           Chat[]           @relation("BuyerChats")
  sellerChats          Chat[]           @relation("SellerChats")
  messages             Message[]
  buyerOrders          Order[]          @relation("BuyerRelation")
  ratings              Rating[]
  store                Store?
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  parentId  String?
  level     Int        @default(0)
  sortOrder Int        @default(0)
  image     String?
  icon      String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  products  Product[]  @relation("CategoryToProduct")
}

model Product {
  id               String      @id @default(cuid())
  name             String
  description      String
  mrp              Float
  price            Float
  images           Json        @default("[]")
  videos           Json?       @default("[]")
  category         String?
  categoryId       String?
  categoryData     Category?   @relation("CategoryToProduct", fields: [categoryId], references: [id])
  inStock          Boolean     @default(true)
  stock            Int         @default(0)
  weight           Float       @default(0.0)
  length           Float       @default(0.0)
  width            Float       @default(0.0)
  height           Float       @default(0.0)
  condition        String      @default("New")
  preOrder         Boolean     @default(false)
  parent_sku       String?
  tier_variations  Json?       @default("[]")
  variation_matrix Json?       @default("[]")
  hidden_combos    Json?       @default("[]")
  storeId          String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  cartItems        CartItem[]
  orderItems   OrderItem[]
  store        Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rating       Rating[]
}

model Order {
  id                  String        @id @default(cuid())
  total               Float
  shippingCost        Float         @default(0)
  status              OrderStatus   @default(ORDER_PLACED)
  userId              String
  storeId             String
  addressId           String
  isPaid              Boolean       @default(false)
  paymentMethod       PaymentMethod
  paymentSourceId     String?
  paymentId           String?
  paymentStatus       String?
  paidAt              DateTime?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  completedAt         DateTime?
  autoCompleteAt      DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  isCouponUsed        Boolean       @default(false)
  coupon              Json          @default("{}")
  shipping            Json?
  isGuaranteeExtended Boolean       @default(false)
  address             Address       @relation(fields: [addressId], references: [id])
  store               Store         @relation(fields: [storeId], references: [id])
  user                User          @relation("BuyerRelation", fields: [userId], references: [id])
  orderItems          OrderItem[]
  paymentProof        PaymentProof?
  returns             Return[]
  checkoutId          String?
}

model Checkout {
  id              String    @id @default(cuid())
  userId          String
  total           Float
  currency        String    @default("PHP")
  status          String    @default("PENDING")
  expiresAt       DateTime?
  sessionId       String?   @unique
  metadata        String?   @db.Text
  attemptCount    Int       @default(0)
  paymentId       String?
  paymentProvider String?
  expiredAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}


model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  variationId String?
  quantity    Int
  price       Float
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([orderId, productId, variationId])
}

model Rating {
  id        String   @id @default(cuid())
  rating    Int
  review    String
  userId    String
  productId String
  orderId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, orderId])
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  name         String
  email        String
  houseNumber  String?
  street       String
  barangay     String
  subdivision  String?
  landmark     String?
  city         String
  state        String
  zip          String
  country      String   @default("Philippines")
  phone        String
  latitude     Float?
  longitude    Float?
  buildingName String?
  floorUnit    String?
  notes        String?
  label        String?  @default("")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Order        Order[]
}

model Coupon {
  code          String   @id
  description   String
  discount      Float
  forNewUser    Boolean
  forMember     Boolean  @default(false)
  forCoopMember Boolean  @default(false)
  isPublic      Boolean
  expiresAt     DateTime
  storeId       String?
  createdAt     DateTime @default(now())
}

model Store {
  id                 String             @id @default(cuid())
  userId             String             @unique
  name               String
  description        String
  username           String             @unique
  address            String
  status             String             @default("pending")
  isActive           Boolean            @default(false)
  logo               String
  email              String
  contact            String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  latitude           Float?
  longitude          Float?
  shippingProfile    Json?
  kycDocuments       Json?              @default("[]")
  verificationStatus VerificationStatus @default(PENDING)
  verificationNotes  String?
  nonFulfilmentRate  Float?             @default(0.0)
  penaltyPoints      Int?               @default(0)
  chats              Chat[]
  Order              Order[]
  payoutRequests     PayoutRequest[]
  Product            Product[]
  user               User               @relation(fields: [userId], references: [id])
  addresses          StoreAddress[]
  wallet             Wallet?
}

model StoreAddress {
  id              String   @id @default(cuid())
  storeId         String
  phone           String
  district        String
  province        String?
  city            String
  barangay        String
  detailedAddress String
  zip             String
  country         String   @default("Philippines")
  notes           String?
  label           String?  @default("")
  latitude        Float?
  longitude       Float?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  productId   String
  variationId String?
  quantity    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variationId])
}

model Wallet {
  id             String        @id @default(cuid())
  storeId        String        @unique
  balance        Float         @default(0)
  pendingBalance Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lockedBalance  Float         @default(0)
  transactions   Transaction[]
  store          Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String          @id @default(cuid())
  walletId    String
  amount      Float
  type        TransactionType
  description String
  createdAt   DateTime        @default(now())
  wallet      Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model PayoutRequest {
  id        String       @id @default(cuid())
  storeId   String
  amount    Float
  status    PayoutStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  store     Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Return {
  id               String              @id @default(cuid())
  orderId          String
  reason           String
  type             ReturnType          @default(REFUND_ONLY)
  refundAmount     Float               @default(0)
  images           Json                @default("[]")
  status           ReturnStatus        @default(PENDING)
  sellerAction     ReturnSellerAction?
  sellerReason     String?
  trackingNumber   String?
  deadline         DateTime?
  arbitrationNotes String?
  adminId          String?
  adminNotes       String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  isEscrowLocked   Boolean             @default(false)
  returnShipping   Json?
  order            Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model PaymentProof {
  id        String             @id @default(cuid())
  orderId   String             @unique
  imageUrl  String
  refNumber String?
  notes     String?
  status    VerificationStatus @default(PENDING)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  order     Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Chat {
  id        String    @id @default(cuid())
  buyerId   String
  sellerId  String
  storeId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  buyer     User      @relation("BuyerChats", fields: [buyerId], references: [id], onDelete: Cascade)
  seller    User      @relation("SellerChats", fields: [sellerId], references: [id], onDelete: Cascade)
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([buyerId, storeId])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventType   String
  payload     Json
  status      String
  error       String?
  orderId     String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([orderId])
  @@index([provider, eventType])
}

model SystemSettings {
  id                         String   @id @default("default")
  realtimeProvider           String   @default("POLLING")
  pusherKey                  String?
  pusherCluster              String?
  pusherAppId                String?
  pusherSecret               String?
  socketUrl                  String?
  swrPollingInterval         Int      @default(10000)
  sessionTimeout             Int      @default(15)
  sessionWarning             Int      @default(1)
  loginLimit                 Int      @default(10)
  registerLimit              Int      @default(5)
  updatedAt                  DateTime @default(now()) @updatedAt
  cacheProvider              String   @default("MEMORY")
  redisPassword              String?
  redisUrl                   String?
  marketingAdsEnabled        Boolean  @default(false)
  quickInstallerEnabled      Boolean  @default(true)
  adDisplayMode              String   @default("SEQUENCE")
  selectedMarketingAds       String[] @default([])
  marketingAdConfigs         Json?    @default("[]")
  errorTrackingEnabled       Boolean  @default(false)
  sentryDsn                  String?
  sentryEnvironment          String?  @default("production")
  sentryTracesSampleRate     Float?   @default(0.1)
  orderCancellationHours     Int      @default(48)
  orderCancellationEnabled   Boolean  @default(true)
  protectionWindowDays       Int      @default(3)
  budolShapShippingEnabled   Boolean  @default(false)
  budolShapShippingSLADays   Int      @default(3)
  budolShapWaybillGeneration Boolean  @default(false)
  enabledMapProviders        String[] @default(["OSM"])
  geoapifyApiKey             String?
  googleMapsApiKey           String?
  mapProvider                String   @default("OSM")
  radarApiKey                String?
  maxProductImages           Int      @default(12)
  maxProductVideos           Int      @default(0)
  
  // Email Provider Settings (Added in v19)
  emailProvider              String?  @default("CONSOLE")
  smtpHost                   String?
  smtpPort                   Int?
  smtpUser                   String?
  smtpPass                   String?
  smtpFrom                   String?
  brevoApiKey                String?
  gmassApiKey                String?
  
  // SMS Provider Settings (Added in v19)
  smsProvider                String?  @default("CONSOLE")
  zerixApiKey                String?
  itextmoApiKey              String?
  itextmoClientCode          String?
  viberApiKey                String?
  brevoSmsApiKey             String?
}

model RateLimit {
  key      String @id
  points   Int    @default(0)
  expireAt BigInt
}

model VerificationCode {
  id         String   @id @default(cuid())
  identifier String   @unique
  code       String
  expiresAt  DateTime
  type       String   @default("LOGIN")
  createdAt  DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  details   String?
  status    String?  @default("SUCCESS")
  metadata  Json?    @default("{}")
  ipAddress String?
  latitude  String?
  longitude String?
  country   String?
  city      String?
  device    String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum OrderStatus {
  ORDER_PLACED
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURN_DISPUTED
  REFUNDED
  COMPLETED
  CANCELLED
  IN_TRANSIT
  PENDING_VERIFICATION
}

enum PaymentMethod {
  COD
  STRIPE
  GCASH
  BUDOL_PAY
  MAYA
  GRAB_PAY
  QRPH
}

enum AccountType {
  BUYER
  SELLER
  ADMIN
}

enum MembershipStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReturnStatus {
  PENDING
  APPROVED
  BOOKING_REQUESTED
  BOOKED
  SHIPPED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RECEIVED
  REFUNDED
  CANCELLED
  DISPUTED
  TO_PICKUP
}

enum ReturnType {
  REFUND_ONLY
  RETURN_AND_REFUND
}

enum ReturnSellerAction {
  ACCEPT
  REJECT

  OFFER_PARTIAL
  REQUEST_RETURN
}


