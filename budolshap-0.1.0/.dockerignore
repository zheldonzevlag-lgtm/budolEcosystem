# Docker ignore file for budolshap frontend
# Purpose: Exclude files from Docker build context
# Created: 2026-03-03

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build output
.next
out
dist
build

# Environment files
.env
.env.local
.env.*.local

# Development files
.git
.gitignore
README.md
.vscode
.idea
*.swp
*.swo

# Test files
coverage
*.test.js
*.test.jsx
*.test.ts
*.test.tsx
__tests__

# OS files
.DS_Store
Thumbs.db

# Large binary files
*.apk
*.ipa
# NOTE: Assets images are needed for build - do not exclude
# assets/*.png
# assets/*.jpg
# assets/*.jpeg
# assets/*.gif
# assets/*.svg

# Documentation
docs
*.md

# Backup files
backup
*.backup

# CI/CD
.github
.gitlab-ci.yml
amplify.yml