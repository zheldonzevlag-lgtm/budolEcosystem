/**
 * Centralized configuration for Shipping Providers and Tracking Stages
 */

export const SHIPPING_PROVIDERS = {
    STANDARD: 'standard',
    LALAMOVE: 'lalamove',
    // Future providers can be added here, e.g., GRAB: 'grab'
};

export const PROVIDER_STAGES = {
    [SHIPPING_PROVIDERS.LALAMOVE]: [
        { label: 'Placed', status: 'ORDER_PLACED', icon: '📝' },
        { label: 'Paid', status: 'PAID', icon: '💳' },
        { label: 'Needs Booking', status: 'PROCESSING', icon: '📦' },
        { label: 'Booked', status: 'PROCESSING', specificStatus: 'ASSIGNING_DRIVER', icon: '📑' },
        {
            label: 'In Transit',
            status: 'IN_TRANSIT',
            specificStatus: ['PICKED_UP', 'IN_TRANSIT', 'ON_GOING'],
            icon: '🚚'
        },
        { label: 'Delivered', status: 'DELIVERED', specificStatus: 'COMPLETED', icon: '✅' }
    ],
    [SHIPPING_PROVIDERS.STANDARD]: [
        { label: 'Placed', status: 'ORDER_PLACED', icon: '📝' },
        { label: 'Paid', status: 'PAID', icon: '💳' },
        { label: 'Needs Booking', status: 'PROCESSING', icon: '📦' },
        { label: 'Booked', status: 'PROCESSING', icon: '📑' },
        { label: 'In Transit', status: 'IN_TRANSIT', icon: '🚚' },
        { label: 'Delivered', status: 'DELIVERED', icon: '✅' }
    ]
};

export const TRACKING_REMARKS = {
    [SHIPPING_PROVIDERS.LALAMOVE]: {
        IN_TRANSIT: "Driver has picked up your package. Package is on the way.",
