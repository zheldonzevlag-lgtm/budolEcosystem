{
    "InstanceIds": [
        "i-0335b8c303baaaee0"
    ],
    "DocumentName": "AWS-RunShellScript",
    "Comment": "Get SSL cert 2 (budolid)",
    "Parameters": {
        "commands": [
            "export DuckDNS_Token=\"db0964a1-387c-419a-9272-f87e38b8a542\"",
            "/.acme.sh/acme.sh --issue --dns dns_duckdns -d budolid.duckdns.org --server letsencrypt --dnssleep 120",
            "cp /.acme.sh/budolid.duckdns.org_ecc/fullchain.cer /home/ubuntu/cert_id.crt || true",
            "cp /.acme.sh/budolid.duckdns.org_ecc/budolid.duckdns.org.key /home/ubuntu/cert_id.key || true"
        ]
    }
}
