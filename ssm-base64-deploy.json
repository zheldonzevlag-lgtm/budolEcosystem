{
    "commands": [
        "mkdir -p /home/ubuntu/budol-ws",
        "echo  | base64 -d > /home/ubuntu/budol-ws/Dockerfile",
        "echo  | base64 -d > /home/ubuntu/budol-ws/package.json",
        "echo  | base64 -d > /home/ubuntu/budol-ws/server.js",
        "sudo chown -R ubuntu:ubuntu /home/ubuntu/budol-ws",
        "cd /home/ubuntu/budol-ws",
        "sudo -u ubuntu docker compose up -d"
    ]
}